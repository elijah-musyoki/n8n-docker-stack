# =============================================================================
# n8n Docker Compose — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Container Versions ------------------------------------------------------
N8N_VERSION=2.29.10
POSTGRES_VERSION=18.4
REDIS_VERSION=8.8.0-alpine

# --- n8n Host (for OAuth/callbacks) -----------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# --- Timezone ----------------------------------------------------------------
GENERIC_TIMEZONE=UTC
TZ=UTC

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=changeUser
POSTGRES_PASSWORD=changePassword
POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=changeUser
POSTGRES_NON_ROOT_PASSWORD=changePassword

# --- Encryption --------------------------------------------------------------
ENCRYPTION_KEY=changeEncryptionKey
N8N_OTEL_TRACES_SAMPLE_RATE=0.1
N8N_ENDPOINT_HEALTH=health/live
WEBHOOK_URL=http://localhost:5678/

# --- Task Runners ------------------------------------------------------------
RUNNERS_AUTH_TOKEN=changeRunnerAuthToken

# --- Redis -------------------------------------------------------------------
REDIS_PASSWORD=changeRedisPassword
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
QUEUE_BULL_REDIS_PORT=6379
